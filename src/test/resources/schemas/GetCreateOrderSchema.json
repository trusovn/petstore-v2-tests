{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["id", "petId", "quantity", "shipDate", "status", "complete"],
  "properties": {
    "id": {
      "type": "integer",
      "minimum": 0
    },
    "petId": {
      "type": "integer",
      "minimum": 0
    },
    "quantity": {
      "type": "integer",
      "minimum": 1
    },
    "shipDate": {
      "type": "string",
      "format": "date-time"
    },
    "status": {
      "type": "string",
      "enum": ["placed", "approved", "delivered"]
    },
    "complete": {
      "type": "boolean"
    }
  }
}